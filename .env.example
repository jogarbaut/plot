# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# ─── Database (Docker Compose runs this locally) ───────────────────────────
DATABASE_URL=postgresql://plot:plot@localhost:5432/plot_dev

# ─── Redis (Docker Compose runs this locally) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth0 ─────────────────────────────────────────────────────────────────
# Get these from your Auth0 dashboard → Applications → your app
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.plot.app
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ─── Next.js (frontend) ────────────────────────────────────────────────────
# NEXT_PUBLIC_ prefix makes vars available in the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=
NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.plot.app

# ─── Third-party APIs (feed data) ──────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=
FOURSQUARE_API_KEY=

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
