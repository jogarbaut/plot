# API environment variables — copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# These vars are ONLY for the FastAPI backend. Never put them in the frontend.

# ─── App ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── Database (docker compose up -d starts this locally) ───────────────────
DATABASE_URL=postgresql://plot:plot@localhost:5432/plot_dev

# ─── Redis (docker compose up -d starts this locally) ──────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth0 ─────────────────────────────────────────────────────────────────
# Get these from Auth0 dashboard → Applications → your API application
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.plot.app

# ─── CORS ──────────────────────────────────────────────────────────────────
# Space-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── Third-party APIs ──────────────────────────────────────────────────────
# These are server-side secrets — never expose them to the frontend
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=
FOURSQUARE_API_KEY=
